# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
#
# Local development (replace USER and PASSWORD with your PostgreSQL credentials):
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/nayab_posh?schema=public"
#
# Supabase example:
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?schema=public"
#
# PlanetScale / Neon / Railway: paste the connection string from your dashboard.

# ── NextAuth ──────────────────────────────────────────────────────────────────
#
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="your_secret_here"
#
# Required in production — set to your canonical app URL:
# AUTH_URL="https://your-domain.com"

# ── Email (Resend) ────────────────────────────────────────────────────────────
#
# Create an account at https://resend.com and generate an API key.
RESEND_API_KEY="re_your_resend_api_key_here"
#
# The "from" address shown in outgoing emails (must be a verified domain in Resend):
EMAIL_FROM="Nayab Posh <noreply@yourdomain.com>"
#
# Where admin notifications (new orders, contact forms, etc.) are delivered:
ADMIN_EMAIL_TO="admin@yourdomain.com"

# ── Cloudinary ────────────────────────────────────────────────────────────────
#
# Find these values in your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Backup & Recovery ─────────────────────────────────────────────────────────
#
# Directory where backup files are written (default: ./backups)
# BACKUP_PATH="./backups"
#
# Number of days to keep backups before automatic deletion (default: 30)
# BACKUP_RETENTION_DAYS="30"
#
# Path to pg_dump / pg_restore binaries (default: assumes they're in PATH)
# On Windows, set these to the full path:
# PG_DUMP_BIN="C:\Program Files\PostgreSQL\16\bin\pg_dump.exe"
# PG_RESTORE_BIN="C:\Program Files\PostgreSQL\16\bin\pg_restore.exe"

# ── Sentry (optional) ─────────────────────────────────────────────────────────
#
# Create a project at https://sentry.io and paste the DSN from Settings → SDK Setup.
# Server-side error tracking (API routes, server components, DB errors):
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
#
# Client-side error tracking (browser JS errors, React component errors):
# NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
#
# Source map uploading (optional — needed for readable stack traces in Sentry UI):
# SENTRY_AUTH_TOKEN="your_auth_token_here"
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="your-project-slug"
